# --- Admin auth ---------------------------------------------------------
# Password required to sign in to /admin. Set a strong value in production.
ADMIN_PASSWORD=change-me

# --- SharePoint embedding ------------------------------------------------
# Your SharePoint tenant origin, allowed to embed this app in an iframe.
# Example: https://yourtenant.sharepoint.com
SHAREPOINT_DOMAIN=https://yourtenant.sharepoint.com

# --- Vercel Blob (app data + icon uploads) -------------------------------
# Auto-populated when you attach a Blob store to this project on Vercel.
# Used both for uploaded icon images and to store the app list itself
# (data/apps.json). For local dev, run `vercel env pull .env.local` after
# creating the store, or leave blank to use the local JSON file fallback
# in .data/apps.json.
BLOB_READ_WRITE_TOKEN=
